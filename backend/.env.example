# Datenbank
DATABASE_URL=postgresql://postgres:flexr@localhost:5432/flexr

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...      # 5€/Monat-Preis in Stripe anlegen
STRIPE_TRIAL_DAYS=30

# Objekt-Storage (S3-kompatibel, z. B. Cloudflare R2) für Foto-Uploads
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=flexr-photos
S3_PUBLIC_BASE_URL=https://photos.flexr.social
S3_REGION=auto

# App
FRONTEND_URL=https://flexr.social
ENV=development
