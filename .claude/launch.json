{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "flexr-backend",
      "runtimeExecutable": "backend/venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "flexr-frontend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "5173", "--directory", "frontend"],
      "port": 5173
    }
  ]
}
